  "homepage": "https://github.com/shippusharma/skills#readme",
  "scripts": {
    "cleanup": "rm -rf node_modules .huksy",
    "list-skills": "chmod +x scripts/list-skills.sh && sh scripts/list-skills.sh",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,css,scss,sass,md,html,json,yml,yaml}\"",
    "format-check": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,css,scss,sass,md,html,json,yml,yaml}\"",
    "==================================================": "==================================================",
    "semvar:init": "changeset init",
    "semvar:changeset": "changeset",
    "semvar:version": "changeset version",
    "semvar:status": "changeset status --verbose",
    "semvar:release": "changeset publish",
    "semvar:tag": "changeset tag",
    "semvar:tag:manually": "VERSION=$(node -p \"require('./package.json').version\") && git tag -a v$VERSION -m \"Release v$VERSION\" && git push origin v$VERSION"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "prettier": "^3.9.6"
  },
  "packageManager": "npm@11.16.0",
  "skills": "./skills/"
}
